{
  "name": "occ-handover-backend",
  "private": true,
  "scripts": {
    "dev": "node ../scripts/run-node-with-root-env.mjs ./node_modules/tsx/dist/cli.mjs watch src/server.ts",
    "build": "node ../scripts/run-node-with-root-env.mjs ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "test": "node ../scripts/run-node-with-root-env.mjs ./node_modules/vitest/vitest.mjs --run --configLoader runner --config ./vitest.config.mts --pool threads --passWithNoTests",
    "test:coverage": "node ../scripts/run-node-with-root-env.mjs ./node_modules/vitest/vitest.mjs --run --configLoader runner --config ./vitest.config.mts --pool threads --coverage --passWithNoTests"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "csv-stringify": "^6.7.0",
    "express": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
