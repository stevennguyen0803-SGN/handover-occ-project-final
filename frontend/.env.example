# NextAuth.js v5 (Auth.js) shared secret. Used to sign JWT session
# tokens AND the X-OCC-AUTH-* headers the frontend sends to the backend.
# Must match BACKEND .env's NEXTAUTH_SECRET (or AUTH_SECRET) exactly.
NEXTAUTH_SECRET=replace-with-a-32-char-random-string

# Optional alias read by some Auth.js versions; keep both pointing at the
# same value during the migration.
AUTH_SECRET=replace-with-a-32-char-random-string

# Pooled connection used by Prisma at runtime (e.g. PgBouncer).
DATABASE_URL=postgresql://occ:occ@localhost:5432/occ?schema=public&pgbouncer=true

# Direct connection used only for migrations / `prisma migrate`.
DIRECT_URL=postgresql://occ:occ@localhost:5432/occ?schema=public

# Base URL of the Express backend the frontend proxies to. The signed
# X-OCC-AUTH-* headers travel server-to-server only.
BACKEND_URL=http://localhost:4000
